# Anthropic (Outreach Agent)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Supabase (Lead Capture)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# LinkedIn API
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=urn:li:person:YOUR_ID

# Twitter/X API (Basic tier required for follows + DMs)
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_SECRET=your_access_secret
TWITTER_USER_ID=your_numeric_user_id

# Supabase (outreach logging)
DB_URL=https://your-project.supabase.co
DB_SERVICE_KEY=your_service_role_key

# Resend (blueprint emails)
RESEND_API_KEY=your_resend_api_key

# Timezone (for cron schedule)
TZ=America/New_York
