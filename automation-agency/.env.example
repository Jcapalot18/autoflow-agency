# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── SMTP (email sending) ──────────────────────────────────────────────────────
# Gmail example: use an App Password (not your account password)
#   Enable 2FA → Google Account → Security → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password

# Displayed as the sender name in outgoing emails
SENDER_NAME=Jason @ AutoFlow
# Optional — if replies should go to a different address than SMTP_USER
REPLY_TO=jason@autoflow-agency.com
